#!/bin/sh

. /lib/functions.sh
. /lib/functions/network.sh

APP="stability-monitor"
SECTION="monitor"
DEFAULT_STORE="/etc/stability-monitor"
RUNTIME_DIR="/var/run/stability-monitor"

log() {
	logger -t "$APP" "$*"
}

json_escape() {
	printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
}

now() {
	date +%s
}

iso_time() {
	date '+%Y-%m-%dT%H:%M:%S%z'
}

epoch_iso_time() {
	local epoch="$1"
	date -d "@$epoch" '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || date -r "$epoch" '+%Y-%m-%dT%H:%M:%S%z' 2>/dev/null || printf '%s' "$epoch"
}

cfg_get() {
	local value
	config_get value "$SECTION" "$1" "$2"
	printf '%s' "$value"
}

uint_at_least() {
	local value="$1"
	local default="$2"
	local minimum="$3"

	case "$value" in
		''|*[!0-9]*)
			printf '%s' "$default"
			return
			;;
	esac

	if [ "$value" -lt "$minimum" ]; then
		printf '%s' "$default"
	else
		printf '%s' "$value"
	fi
}

load_settings() {
	config_load "$APP"

	interface="$(cfg_get interface wan)"
	targets="$(cfg_get targets '1.1.1.1 8.8.8.8')"
	interval="$(cfg_get interval 1)"
	timeout="$(cfg_get timeout 1)"
	fail_threshold="$(cfg_get fail_threshold 3)"
	recovery_threshold="$(cfg_get recovery_threshold 3)"
	retention_days="$(cfg_get retention_days 30)"
	storage_path="$(cfg_get storage_path "$DEFAULT_STORE")"
	flush_seconds="$(cfg_get flush_seconds 60)"
	iperf_enabled="$(cfg_get iperf_enabled 0)"
	iperf_server="$(cfg_get iperf_server '')"
	iperf_port="$(cfg_get iperf_port 5201)"
	iperf_interval="$(cfg_get iperf_interval 3600)"
	iperf_duration="$(cfg_get iperf_duration 10)"
	iperf_parallel="$(cfg_get iperf_parallel 1)"
	iperf_direction="$(cfg_get iperf_direction download)"

	interval="$(uint_at_least "$interval" 1 1)"
	timeout="$(uint_at_least "$timeout" 1 1)"
	fail_threshold="$(uint_at_least "$fail_threshold" 3 1)"
	recovery_threshold="$(uint_at_least "$recovery_threshold" 3 1)"
	retention_days="$(uint_at_least "$retention_days" 30 1)"
	flush_seconds="$(uint_at_least "$flush_seconds" 60 10)"
	iperf_port="$(uint_at_least "$iperf_port" 5201 1)"
	iperf_interval="$(uint_at_least "$iperf_interval" 3600 60)"
	iperf_duration="$(uint_at_least "$iperf_duration" 10 1)"
	iperf_parallel="$(uint_at_least "$iperf_parallel" 1 1)"
	[ "$iperf_enabled" = 1 ] || iperf_enabled=0
	case "$iperf_direction" in download|upload) ;; *) iperf_direction=download ;; esac
	[ -n "$iperf_server" ] || iperf_enabled=0

	case "$storage_path" in
		/*) ;;
		*) storage_path="$DEFAULT_STORE" ;;
	esac

	status_file="$RUNTIME_DIR/status.json"
	bucket_file="$storage_path/minute-buckets.jsonl"
	outage_file="$storage_path/outages.jsonl"
	speed_file="$storage_path/speed-tests.jsonl"
	pid_file="$RUNTIME_DIR/monitor.pid"
	iperf_output="$RUNTIME_DIR/iperf3.json"

	mkdir -p "$storage_path"
	mkdir -p "$RUNTIME_DIR"
}

restore_history() {
	local summary

	if [ -f "$bucket_file" ]; then
		summary="$(awk '
			function field(name, line, value) {
				value = line
				sub("^.*\"" name "\":", "", value)
				sub(/[,}].*$/, "", value)
				return value
			}
			{
				probes += field("probes", $0) + 0
				failures += field("failures", $0) + 0
				successes = field("successes", $0) + 0
				avg = field("avg_latency_ms", $0)
				min_value = field("min_latency_ms", $0)
				max_value = field("max_latency_ms", $0)
				outages += field("outages", $0) + 0

				if (avg != "null" && successes > 0) {
					latency_sum += avg * successes
					latency_count += successes
				}
				if (min_value != "null" && (!has_min || min_value + 0 < min_latency)) {
					min_latency = min_value + 0
					has_min = 1
				}
				if (max_value != "null" && (!has_max || max_value + 0 > max_latency)) {
					max_latency = max_value + 0
					has_max = 1
				}
			}
			END {
				printf "%d %d %.3f %d ", probes, failures, latency_sum, latency_count
				if (has_min) printf "%.3f", min_latency; else printf "null"
				printf " "
				if (has_max) printf "%.3f", max_latency; else printf "null"
				printf " %d", outages
			}
		' "$bucket_file")"
		set -- $summary
		total_probes="${1:-0}"
		total_failures="${2:-0}"
		stored_latency_sum="${3:-0}"
		stored_latency_count="${4:-0}"
		stored_min_latency="${5:-null}"
		stored_max_latency="${6:-null}"
		stored_outages="${7:-0}"
	fi

	if [ -f "$outage_file" ]; then
		summary="$(awk '
			function number_field(name, line, value) {
				value = line
				sub("^.*\"" name "\":", "", value)
				sub("[^0-9].*$", "", value)
				return value + 0
			}
			{
				start = number_field("start", $0)
				end = number_field("end", $0)
				duration = number_field("duration", $0)
				count++
				total += duration
				if (duration > longest) longest = duration
				last_start = start
				last_end = end
				last_duration = duration
			}
			END { printf "%d %d %d %d %d %d", count, total, longest, last_start, last_end, last_duration }
		' "$outage_file")"
		set -- $summary
		outage_count="${1:-0}"
		total_downtime="${2:-0}"
		longest_outage="${3:-0}"
		last_outage_start="${4:-}"
		last_outage_end="${5:-}"
		last_outage_duration="${6:-0}"
		[ "$last_outage_start" = 0 ] && last_outage_start=""
		[ "$last_outage_end" = 0 ] && last_outage_end=""
	fi

	if [ -f "$speed_file" ]; then
		summary="$(awk '
			function field(name, line, value) {
				value = line
				sub("^.*\"" name "\":", "", value)
				sub(/[,}].*$/, "", value)
				return value
			}
			{
				count++
				bps = field("bits_per_second", $0) + 0
				sum += bps
				if (!has_min || bps < min) min = bps
				if (!has_max || bps > max) max = bps
				has_min = has_max = 1
			}
			END { printf "%d %.0f %.0f %.0f", count, sum, min, max }
		' "$speed_file")"
		set -- $summary
		speed_test_count="${1:-0}"
		speed_sum_bps="${2:-0}"
		speed_min_bps="${3:-0}"
		speed_max_bps="${4:-0}"
	fi
}

resolve_device() {
	device=""
	bind_address=""

	network_flush_cache
	network_get_device device "$interface"
	network_get_ipaddr bind_address "$interface"

	if [ -z "$device" ]; then
		device="$interface"
	fi
}

ping_once() {
	local target="$1"
	local output rtt

	output="$(ping -4 -I "$device" -c 1 -W "$timeout" "$target" 2>/dev/null)"
	if [ $? -ne 0 ]; then
		return 1
	fi

	rtt="$(printf '%s\n' "$output" | sed -n 's/.*time=\([0-9.][0-9.]*\).*/\1/p' | head -n 1)"
	[ -n "$rtt" ] || return 1
	last_latency="$rtt"
	return 0
}

write_status() {
	local tmp="$status_file.$$"
	local ts iso outage_json last_start last_end stored_avg speed_avg speed_last_json

	ts="$(now)"
	iso="$(iso_time)"
	last_start=""
	last_end=""
	outage_json="null"
	stored_avg="null"
	speed_avg="null"
	speed_last_json="null"

	if [ "$stored_latency_count" -gt 0 ]; then
		stored_avg="$(awk -v sum="$stored_latency_sum" -v count="$stored_latency_count" 'BEGIN { printf "%.3f", sum / count }')"
	fi
	if [ "$speed_test_count" -gt 0 ]; then
		speed_avg="$(awk -v sum="$speed_sum_bps" -v count="$speed_test_count" 'BEGIN { printf "%.0f", sum / count }')"
	fi
	if [ -n "$last_speed_time" ]; then
		speed_last_json="{\"timestamp\":$last_speed_time,\"bits_per_second\":$last_speed_bps,\"direction\":\"$(json_escape "$last_speed_direction")\"}"
	fi

	if [ -n "$last_outage_start" ]; then
		last_start="$(epoch_iso_time "$last_outage_start")"
		last_end="$(epoch_iso_time "$last_outage_end")"
		outage_json="{\"start\":$last_outage_start,\"end\":$last_outage_end,\"duration\":$last_outage_duration,\"start_iso\":\"$(json_escape "$last_start")\",\"end_iso\":\"$(json_escape "$last_end")\"}"
	fi

	cat > "$tmp" <<EOF
{
  "timestamp": $ts,
  "timestamp_iso": "$(json_escape "$iso")",
  "interface": "$(json_escape "$interface")",
  "device": "$(json_escape "$device")",
  "targets": "$(json_escape "$targets")",
  "state": "$state",
  "current_latency_ms": ${current_latency:-null},
  "recent_loss_percent": $recent_loss,
  "total_probes": $total_probes,
  "total_failures": $total_failures,
  "outage_count": $outage_count,
  "longest_outage": $longest_outage,
  "total_downtime": $total_downtime,
  "all_time": {"min_latency_ms":$stored_min_latency,"avg_latency_ms":$stored_avg,"max_latency_ms":$stored_max_latency,"outages":$stored_outages},
	"iperf": {"enabled":$iperf_enabled,"running":$iperf_running,"server":"$(json_escape "$iperf_server")","direction":"$(json_escape "$iperf_direction")","last_test":$speed_last_json,"all_time":{"tests":$speed_test_count,"min_bits_per_second":$speed_min_bps,"avg_bits_per_second":$speed_avg,"max_bits_per_second":$speed_max_bps}},
  "last_outage": $outage_json,
  "consecutive_failures": $consecutive_failures,
  "consecutive_successes": $consecutive_successes
}
EOF
	mv "$tmp" "$status_file"
}

flush_bucket() {
	local tmp_start avg min_json max_json loss

	[ "$bucket_probes" -gt 0 ] || return 0

	tmp_start="$bucket_start"
	avg="null"
	min_json="null"
	max_json="null"
	loss=0

	if [ "$bucket_successes" -gt 0 ]; then
		avg="$(awk -v sum="$bucket_latency_sum" -v n="$bucket_successes" 'BEGIN { printf "%.3f", sum / n }')"
		min_json="$bucket_min"
		max_json="$bucket_max"
	fi

	loss="$(awk -v fail="$bucket_failures" -v total="$bucket_probes" 'BEGIN { printf "%.2f", (fail * 100) / total }')"

	printf '{"start":%s,"end":%s,"interface":"%s","device":"%s","probes":%s,"successes":%s,"failures":%s,"loss_percent":%s,"avg_latency_ms":%s,"min_latency_ms":%s,"max_latency_ms":%s,"outages":%s,"downtime":%s}\n' \
		"$tmp_start" "$(now)" "$(json_escape "$interface")" "$(json_escape "$device")" \
		"$bucket_probes" "$bucket_successes" "$bucket_failures" "$loss" \
		"$avg" "$min_json" "$max_json" "$bucket_outages" "$bucket_downtime" >> "$bucket_file"

	if [ "$bucket_successes" -gt 0 ]; then
		stored_latency_sum="$(awk -v sum="$stored_latency_sum" -v add="$bucket_latency_sum" 'BEGIN { printf "%.3f", sum + add }')"
		stored_latency_count=$((stored_latency_count + bucket_successes))

		if [ "$stored_min_latency" = "null" ] || awk -v a="$bucket_min" -v b="$stored_min_latency" 'BEGIN { exit !(a < b) }'; then
			stored_min_latency="$bucket_min"
		fi
		if [ "$stored_max_latency" = "null" ] || awk -v a="$bucket_max" -v b="$stored_max_latency" 'BEGIN { exit !(a > b) }'; then
			stored_max_latency="$bucket_max"
		fi
	fi
	stored_outages=$((stored_outages + bucket_outages))

	bucket_start="$(now)"
	bucket_probes=0
	bucket_successes=0
	bucket_failures=0
	bucket_latency_sum=0
	bucket_min=""
	bucket_max=""
	bucket_outages=0
	bucket_downtime=0
}

record_outage() {
	local start="$1"
	local end="$2"
	local duration="$3"
	local start_iso end_iso

	start_iso="$(epoch_iso_time "$start")"
	end_iso="$(epoch_iso_time "$end")"

	printf '{"start":%s,"end":%s,"duration":%s,"start_iso":"%s","end_iso":"%s","interface":"%s","device":"%s"}\n' \
		"$start" "$end" "$duration" "$(json_escape "$start_iso")" "$(json_escape "$end_iso")" \
		"$(json_escape "$interface")" "$(json_escape "$device")" >> "$outage_file"
}

prune_storage() {
	local cutoff tmp

	cutoff=$(( $(now) - retention_days * 86400 ))

	for file in "$bucket_file" "$outage_file" "$speed_file"; do
		[ -f "$file" ] || continue
		tmp="$file.$$"
		awk -v cutoff="$cutoff" '
			{
				start = $0
				sub(/^.*"start":/, "", start)
				sub(/[^0-9].*$/, "", start)
				if (start >= cutoff) print
			}
		' "$file" > "$tmp" && mv "$tmp" "$file"
	done
}

handle_result() {
	local ok="$1"
	local ts duration

	ts="$(now)"
	total_probes=$((total_probes + 1))
	bucket_probes=$((bucket_probes + 1))

	if [ "$ok" = 1 ]; then
		consecutive_successes=$((consecutive_successes + 1))
		consecutive_failures=0
		first_failure_time=""
		bucket_successes=$((bucket_successes + 1))
		current_latency="$last_latency"
		bucket_latency_sum="$(awk -v sum="$bucket_latency_sum" -v rtt="$last_latency" 'BEGIN { printf "%.3f", sum + rtt }')"

		if [ -z "$bucket_min" ] || awk -v a="$last_latency" -v b="$bucket_min" 'BEGIN { exit !(a < b) }'; then
			bucket_min="$last_latency"
		fi
		if [ -z "$bucket_max" ] || awk -v a="$last_latency" -v b="$bucket_max" 'BEGIN { exit !(a > b) }'; then
			bucket_max="$last_latency"
		fi

		if [ "$state" = "degraded" ] && [ "$consecutive_successes" -ge "$recovery_threshold" ]; then
			state="online"
		fi

		if [ "$state" = "offline" ] && [ "$consecutive_successes" -ge "$recovery_threshold" ]; then
			state="online"
			outage_end="$ts"
			duration=$((outage_end - outage_start))
			last_outage_start="$outage_start"
			last_outage_end="$outage_end"
			last_outage_duration="$duration"
			outage_count=$((outage_count + 1))
			bucket_outages=$((bucket_outages + 1))
			total_downtime=$((total_downtime + duration))
			bucket_downtime=$((bucket_downtime + duration))
			[ "$duration" -gt "$longest_outage" ] && longest_outage="$duration"
			record_outage "$outage_start" "$outage_end" "$duration"
			outage_start=""
		fi
	else
		if [ "$consecutive_failures" -eq 0 ]; then
			first_failure_time="$ts"
		fi
		consecutive_failures=$((consecutive_failures + 1))
		consecutive_successes=0
		total_failures=$((total_failures + 1))
		bucket_failures=$((bucket_failures + 1))

		if [ "$state" = "online" ] && [ "$consecutive_failures" -gt 0 ]; then
			state="degraded"
		fi
		if [ "$state" != "offline" ] && [ "$consecutive_failures" -ge "$fail_threshold" ]; then
			state="offline"
			outage_start="$first_failure_time"
			current_latency="null"
		fi
	fi

	recent_loss="$(awk -v fail="$bucket_failures" -v total="$bucket_probes" 'BEGIN { if (total == 0) print "0.00"; else printf "%.2f", (fail * 100) / total }')"
}

probe_cycle() {
	local target ok

	ok=0
	resolve_device

	for target in $targets; do
		if ping_once "$target"; then
			ok=1
			break
		fi
	done

	handle_result "$ok"
}

start_speed_test() {
	local ts

	[ "$iperf_enabled" = 1 ] || return 0
	[ "$iperf_running" = 0 ] || return 0
	ts="$(now)"
	[ $((ts - last_iperf_start)) -ge "$iperf_interval" ] || return 0

	resolve_device
	rm -f "$iperf_output"
	if [ "$iperf_direction" = download ]; then
		if [ -n "$bind_address" ]; then
			iperf3 -c "$iperf_server" -p "$iperf_port" -t "$iperf_duration" -P "$iperf_parallel" -R -B "$bind_address" -J > "$iperf_output" 2>/dev/null &
		else
			iperf3 -c "$iperf_server" -p "$iperf_port" -t "$iperf_duration" -P "$iperf_parallel" -R -J > "$iperf_output" 2>/dev/null &
		fi
	else
		if [ -n "$bind_address" ]; then
			iperf3 -c "$iperf_server" -p "$iperf_port" -t "$iperf_duration" -P "$iperf_parallel" -B "$bind_address" -J > "$iperf_output" 2>/dev/null &
		else
			iperf3 -c "$iperf_server" -p "$iperf_port" -t "$iperf_duration" -P "$iperf_parallel" -J > "$iperf_output" 2>/dev/null &
		fi
	fi
	iperf_pid=$!
	iperf_running=1
	last_iperf_start="$ts"
	log "started $iperf_direction speed test to $iperf_server:$iperf_port"
}

finish_speed_test() {
	local bps ts

	[ "$iperf_running" = 1 ] || return 0
	if kill -0 "$iperf_pid" 2>/dev/null; then
		return 0
	fi
	wait "$iperf_pid" 2>/dev/null
	iperf_running=0

	if [ "$iperf_direction" = download ]; then
		bps="$(jsonfilter -i "$iperf_output" -e '@.end.sum_received.bits_per_second' 2>/dev/null)"
	else
		bps="$(jsonfilter -i "$iperf_output" -e '@.end.sum_sent.bits_per_second' 2>/dev/null)"
	fi
	case "$bps" in ''|*[!0-9.]*) log "speed test failed"; rm -f "$iperf_output"; return 0 ;; esac

	ts="$(now)"
	bps="$(awk -v value="$bps" 'BEGIN { printf "%.0f", value }')"
	printf '{"start":%s,"end":%s,"server":"%s","port":%s,"direction":"%s","duration":%s,"parallel":%s,"bits_per_second":%s}\n' \
		"$last_iperf_start" "$ts" "$(json_escape "$iperf_server")" "$iperf_port" \
		"$iperf_direction" "$iperf_duration" "$iperf_parallel" "$bps" >> "$speed_file"

	last_speed_time="$ts"
	last_speed_bps="$bps"
	last_speed_direction="$iperf_direction"
	speed_test_count=$((speed_test_count + 1))
	speed_sum_bps="$(awk -v sum="$speed_sum_bps" -v add="$bps" 'BEGIN { printf "%.0f", sum + add }')"
	if [ "$speed_test_count" -eq 1 ] || awk -v a="$bps" -v b="$speed_min_bps" 'BEGIN { exit !(a < b) }'; then speed_min_bps="$bps"; fi
	if [ "$speed_test_count" -eq 1 ] || awk -v a="$bps" -v b="$speed_max_bps" 'BEGIN { exit !(a > b) }'; then speed_max_bps="$bps"; fi
	rm -f "$iperf_output"
	log "completed $iperf_direction speed test at $bps bits/s"
}

stop_monitor() {
	if [ "$iperf_running" = 1 ]; then
		kill "$iperf_pid" 2>/dev/null
		wait "$iperf_pid" 2>/dev/null
	fi
	rm -f "$iperf_output"
	flush_bucket
	state="stopped"
	current_latency="null"
	write_status
	rm -f "$pid_file"
	exit 0
}

main() {
	load_settings
	echo "$$" > "$pid_file"
	trap stop_monitor INT TERM

	state="online"
	current_latency="null"
	recent_loss="0.00"
	consecutive_failures=0
	consecutive_successes=0
	total_probes=0
	total_failures=0
	outage_count=0
	longest_outage=0
	total_downtime=0
	stored_latency_sum=0
	stored_latency_count=0
	stored_min_latency="null"
	stored_max_latency="null"
	stored_outages=0
	last_outage_start=""
	last_outage_end=""
	last_outage_duration=0
	outage_start=""
	first_failure_time=""
	iperf_running=0
	iperf_pid=""
	last_iperf_start=0
	last_speed_time=""
	last_speed_bps=0
	last_speed_direction="$iperf_direction"
	speed_test_count=0
	speed_sum_bps=0
	speed_min_bps=0
	speed_max_bps=0

	bucket_start="$(now)"
	bucket_probes=0
	bucket_successes=0
	bucket_failures=0
	bucket_latency_sum=0
	bucket_min=""
	bucket_max=""
	bucket_outages=0
	bucket_downtime=0
	last_flush="$(now)"
	last_prune="$(now)"
	restore_history

	write_status
	log "started monitoring interface $interface via targets: $targets"

	while :; do
		probe_cycle
		finish_speed_test
		start_speed_test
		write_status

		if [ $(( $(now) - last_flush )) -ge "$flush_seconds" ]; then
			flush_bucket
			last_flush="$(now)"
		fi

		if [ $(( $(now) - last_prune )) -ge 3600 ]; then
			prune_storage
			stored_latency_sum=0
			stored_latency_count=0
			stored_min_latency="null"
			stored_max_latency="null"
			stored_outages=0
			speed_test_count=0
			speed_sum_bps=0
			speed_min_bps=0
			speed_max_bps=0
			restore_history
			write_status
			last_prune="$(now)"
		fi

		sleep "$interval"
	done
}

main "$@"
